# BELMONT OPS AGENT - ENVIRONMENT VARIABLES
# Copy this to .env and fill in real values
# NEVER commit .env to version control

# Anthropic (Claude Managed Agents)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_TOKEN=your_telegram_token

# JobTread
JOBTREAD_API_KEY=your_jobtread_api_key

# QuickBooks Online
QBO_ACCESS_TOKEN=your_qbo_access_token
QBO_REALM_ID=your_qbo_realm_id
QBO_REFRESH_TOKEN=your_qbo_refresh_token
QBO_CLIENT_ID=your_qbo_client_id
QBO_CLIENT_SECRET=your_qbo_client_secret

# Meta Business Suite
META_ACCESS_TOKEN=your_meta_access_token
META_PAGE_ID=your_meta_page_id
META_AD_ACCOUNT_ID=your_meta_ad_account_id

# Zep Memory
ZEP_API_KEY=your_zep_api_key
ZEP_USER_ID=jacob_cota

# MCP Server (internal)
MCP_SERVER_URL=https://belmont-mcp.railway.app
MCP_SERVER_SECRET=generate_a_random_secret_here
SELF_URL=https://belmont-telegram.railway.app
JACOB_CHAT_ID=your_telegram_chat_id

# Phase 2 (add when ready)
# HUBSPOT_API_KEY=
# APOLLO_API_KEY=
# OPENAI_API_KEY=